{
  "name": "changelink-autoads",
  "version": "2.5.10",
  "description": "ChangeLink - 广告链接自动化管理系统",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_NO_WARNINGS=1 next dev",
    "dev:custom": "NODE_NO_WARNINGS=1 npx tsx custom-server.js",
    "dev:preview": "NODE_NO_WARNINGS=1 NEXT_PUBLIC_DEPLOYMENT_ENV=preview next dev",
    "dev:production": "NODE_NO_WARNINGS=1 NEXT_PUBLIC_DEPLOYMENT_ENV=production NODE_ENV=production next dev",
    "build": "npx prisma generate && next build",
    "build:preview": "npx prisma generate && NEXT_PUBLIC_DEPLOYMENT_ENV=preview next build",
    "build:production": "npx prisma generate && NEXT_PUBLIC_DEPLOYMENT_ENV=production NODE_ENV=production next build",
    "build:standalone": "npx prisma generate && NODE_ENV=production next build",
    "build:simple": "npx prisma generate && next build",
    "config:dev": "./scripts/switch-config.sh development",
    "config:prod": "./scripts/switch-config.sh production",
    "env:dev": "docker-compose -f docker/docker-compose.yml up -d",
    "env:preview": "docker-compose -f docker/docker-compose.preview.yml up -d",
    "env:prod": "docker-compose -f docker/docker-compose.prod.yml up -d",
    "verify:dev": "./scripts/verify-deployment.sh dev",
    "verify:preview": "./scripts/post-deploy-verification.sh preview",
    "verify:prod": "./scripts/verify-deployment.sh prod",
    "status": "./scripts/check-deployment-status.sh",
    "start": "NODE_NO_WARNINGS=1 NODE_ENV=production next start",
    "start:next": "NODE_NO_WARNINGS=1 next start",
    "start:preview": "NODE_NO_WARNINGS=1 NEXT_PUBLIC_DEPLOYMENT_ENV=preview next start",
    "start:production": "NODE_NO_WARNINGS=1 NEXT_PUBLIC_DEPLOYMENT_ENV=production NODE_ENV=production next start",
    "start:gc-optimized": "NODE_NO_WARNINGS=1 NODE_OPTIONS=\"--max-old-space-size=640 --max-semi-space-size=64\" node --expose-gc node_modules/.bin/next start",
    "dev:gc-optimized": "NODE_NO_WARNINGS=1 NODE_OPTIONS=\"--max-old-space-size=768 --max-semi-space-size=64\" node --expose-gc node_modules/.bin/next dev",
    "lint": "next lint",
    "test": "jest --config=jest.config.cjs",
    "test:watch": "jest --config=jest.config.cjs --watch",
    "test:coverage": "jest --config=jest.config.cjs --coverage",
    "test:unit": "jest --config=jest.config.cjs --testPathPattern=__tests__/.*\\.(test|spec)\\.(ts|tsx)$ --testPathIgnorePatterns=__tests__/e2e/",
    "test:integration": "jest --config=jest.config.cjs __tests__/integration --detectOpenHandles",
    "test:security": "jest --config=jest.config.cjs --testPathPattern=__tests__/security/.*\\.(test|spec)\\.(ts|tsx)$",
    "test:performance": "jest --config=jest.config.cjs --testPathPattern=__tests__/performance/.*\\.(test|spec)\\.(ts|tsx)$",
    "type-check": "tsc --noEmit --skipLibCheck",
    "type-check:strict": "tsc --noEmit --strict",
    "type-check:ci": "./scripts/type-check-ci.sh",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "validate": "npm run type-check && npm run lint",
    "quality-check": "./scripts/quality-check.sh",
    "security-check": "./scripts/security-check.sh",
    "dev:docker": "docker-compose -f docker/docker-compose.dev.yml up -d",
    "dev:docker:stop": "docker-compose -f docker/docker-compose.dev.yml down",
    "dev:docker:logs": "docker-compose -f docker/docker-compose.dev.yml logs -f",
    "clean": "rm -rf .next out dist",
    "migrate:roles": "./scripts/migrate-roles.sh",
    "migrate-tokens": "tsx scripts/migrate-to-unified-tokens.ts",
    "prebuild": "npx prisma generate",
    "postinstall": "npx prisma generate || echo 'Prisma generate failed, continuing...'",
    "build:with-prisma": "./scripts/build-with-prisma.sh",
    "analyze": "ANALYZE=true npm run build",
    "postbuild": "echo '✅ 构建完成！'",
    "test:production": "node -r ts-node/register src/lib/siterank/production-test.ts",
    "test:similarweb": "node -r ts-node/register src/lib/siterank/production-test.ts",
    "docker:build": "docker build -t admin-system:latest .",
    "docker:build:preview": "docker build -t admin-system:preview .",
    "docker:build:prod": "docker build -t admin-system:prod .",
    "docker:build:push": "./docker-build-optimized.sh --tag prod-latest --push",
    "docker:run": "docker run -p 3000:3000 --env-file .env.local url-batch-checker:latest",
    "docker:run:optimized": "docker-compose -f docker-compose.optimized.yml up",
    "docker:test:performance": "./test-docker-performance.sh",
    "docker:clean": "docker system prune -f && docker volume prune -f",
    "docker:logs": "docker logs url-batch-checker-app -f",
    "docker:stop": "docker stop url-batch-checker-app && docker rm url-batch-checker-app",
    "config:validate": "node scripts/validate-config.js",
    "seed:plans": "./scripts/seed-plans.sh",
    "config:optimize": "node scripts/optimize-runtime-config.js",
    "config:migrate": "node scripts/migrate-env-vars.js",
    "check-compatibility": "tsx scripts/check-compatibility.ts",
    "check-compatibility:verbose": "tsx scripts/check-compatibility.ts --verbose",
    "check-compatibility:json": "tsx scripts/check-compatibility.ts --format json",
    "check-compatibility:upgrade": "tsx scripts/check-compatibility.ts --check-upgrade --create-plan",
    "test:report": "tsx scripts/generate-test-report.ts",
    "test:full": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:report",
    "test:comprehensive": "tsx __tests__/comprehensive/test-runner.ts",
    "test:coverage:domain": "jest --testPathPattern=src/modules/.*/domain/.*\\.test\\.(ts|tsx)$ --coverage --coverageDirectory=coverage/domain",
    "test:coverage:application": "jest --testPathPattern=src/modules/.*/application/.*\\.test\\.(ts|tsx)$ --coverage --coverageDirectory=coverage/application",
    "test:coverage:comprehensive": "jest --coverage --coverageDirectory=coverage/comprehensive --testPathPattern=__tests__/comprehensive/.*\\.test\\.(ts|tsx)$",
    "docs:api": "tsx scripts/generate-api-docs.ts",
    "docs:api:watch": "tsx scripts/generate-api-docs.ts --watch",
    "docs:serve": "npx swagger-ui-serve docs/api/openapi.yaml",
    "docs:validate": "swagger-codegen validate -i docs/api/openapi.yaml",
    "config:check": "node scripts/check-deployment.js",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "npx prisma migrate reset --force && npm run db:seed",
    "ci:install": "npm ci --only=production",
    "ci:build": "npm run build",
    "ci:test": "npm run test:unit && npm run test:integration",
    "ci:security": "npm audit --audit-level=high && npm run test:security",
    "ci:lint": "npm run lint && npm run format:check && npm run type-check",
    "deploy:preview": "chmod +x scripts/deploy/deploy.sh && ./scripts/deploy/deploy.sh preview",
    "deploy:production": "./scripts/deploy-health-check.sh production",
    "health:preview": "./scripts/deploy-health-check.sh preview https://urlchecker.dev",
    "health:production": "./scripts/deploy-health-check.sh production https://autoads.dev",
    "verify:production": "./scripts/post-deploy-verification.sh production",
    "monitor:preview": "./scripts/deployment-monitor.sh preview",
    "monitor:production": "./scripts/deployment-monitor.sh production",
    "rollback-trigger:preview": "./scripts/auto-rollback-trigger.sh preview",
    "rollback-trigger:production": "./scripts/auto-rollback-trigger.sh production",
    "notify:success": "./scripts/deployment-notification.sh success",
    "notify:failure": "./scripts/deployment-notification.sh failure",
    "notify:rollback": "./scripts/deployment-notification.sh rollback",
    "migrate": "tsx scripts/migrations/migration-runner.ts",
    "migrate:run": "tsx scripts/migrations/migration-runner.ts run",
    "migrate:status": "tsx scripts/migrations/migration-runner.ts status",
    "migrate:validate": "tsx scripts/migrations/migration-runner.ts validate",
    "migrate:rollback": "tsx scripts/migrations/migration-runner.ts rollback",
    "rollback": "chmod +x scripts/deploy/rollback.sh && ./scripts/deploy/rollback.sh",
    "rollback:analyze": "tsx scripts/migrations/rollback-manager.ts analyze",
    "rollback:safe": "tsx scripts/migrations/rollback-manager.ts rollback",
    "rollback:backup": "tsx scripts/migrations/rollback-manager.ts backup",
    "rollback:restore": "tsx scripts/migrations/rollback-manager.ts restore",
    "rollback:list": "tsx scripts/migrations/rollback-manager.ts list-backups",
    "rollback:cleanup": "tsx scripts/migrations/rollback-manager.ts cleanup",
    "docs:context7": "tsx scripts/generate-context7-docs.ts",
    "docs:context7:watch": "tsx scripts/watch-context7-docs.ts",
    "docs:context7:validate": "tsx scripts/validate-context7-docs.ts",
    "docs:context7:verbose": "tsx scripts/watch-context7-docs.ts --verbose",
    "docs:context7:fast": "tsx scripts/watch-context7-docs.ts --debounce=500 --no-validate",
    "docs:context7:test": "tsx scripts/test-context7-system.ts",
    "docker:build:dev": "docker build -t admin-system:dev .",
    "env:stop": "docker-compose down",
    "env:switch": "chmod +x scripts/deploy/switch-env.sh && ./scripts/deploy/switch-env.sh",
    "deploy:dev": "chmod +x scripts/deploy/deploy.sh && ./scripts/deploy/deploy.sh development",
    "deploy:prod": "chmod +x scripts/deploy/deploy.sh && ./scripts/deploy/deploy.sh production",
    "db:migrate:dev": "NODE_ENV=development npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:seed:dev": "NODE_ENV=development npx prisma db seed",
    "db:reset:dev": "NODE_ENV=development npx prisma migrate reset",
    "test:db": "jest __tests__/integration/database-connection.test.ts",
    "test:health": "curl -f http://localhost:3000/api/health || exit 1",
    "init:deployment": "tsx scripts/init-deployment.ts",
    "validate:env": "tsx scripts/validate-environment.ts",
    "db:manage": "tsx scripts/manage-database.ts",
    "health:check": "chmod +x scripts/deploy/health-check.sh && ./scripts/deploy/health-check.sh",
    "test:compatibility": "jest __tests__/compatibility --detectOpenHandles",
    "test:regression": "jest __tests__/regression --detectOpenHandles",
    "test:core-functions": "jest __tests__/compatibility/core-functions.test.ts",
    "test:permissions": "jest __tests__/compatibility/permission-compatibility.test.ts",
    "test:database-compat": "jest __tests__/compatibility/database-compatibility.test.ts",
    "test:config-impact": "jest __tests__/compatibility/config-change-impact.test.ts",
    "validate:compatibility": "tsx scripts/compatibility/compatibility-validator.ts",
    "test:full-compatibility": "npm run test:compatibility && npm run test:regression && npm run validate:compatibility",
    "build-storybook": "storybook build",
    "fix:auth-accounts": "tsx scripts/fix-auth-accounts.ts",
    "bmad:refresh": "bmad-method install -f -i codex",
    "bmad:list": "bmad-method list:agents",
    "bmad:validate": "bmad-method validate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
