/**
 * Process Crash Logger
 * 记录进程退出原因，帮助诊断容器崩溃问题
 */

import { writeFileSync, existsSync, mkdirSync, appendFileSync } from 'fs';
import { join } from 'path';

const CRASH_LOG_DIR = '/tmp/crash-logs';
const MAX_LOG_ENTRIES = 100; // Limit log entries to prevent storage bloat
const MAX_LOG_SIZE_MB = 5; // 5MB max per log file

export class CrashLogger {
  private static instance: CrashLogger;
  private initialized = false;
  private logEntryCount = 0;
  private currentLogFile: string = '';

  static getInstance(): CrashLogger {
    if (!CrashLogger.instance) {
      CrashLogger.instance = new CrashLogger();
    }
    return CrashLogger.instance;
  }

  initialize(): void {
    if (this.initialized) return;
    
    // 创建日志目录
    if (!existsSync(CRASH_LOG_DIR)) {
      mkdirSync(CRASH_LOG_DIR, { recursive: true });
    }
    
    // Initialize current log file
    this.currentLogFile = join(CRASH_LOG_DIR, `crash-${Date.now()}.log`);
    this.logEntryCount = 0;

    // 记录启动信息
    this.log('APPLICATION_START', {
      timestamp: new Date().toISOString(),
      pid: process.pid,
      version: process.env.npm_package_version || 'unknown',
      nodeVersion: process.version,
      platform: process.platform,
      arch: process.arch,
      memoryUsage: process.memoryUsage(),
      cwd: process.cwd(),
      argv: process.argv,
      env: {
        NODE_ENV: process.env.NODE_ENV,
        NEXT_PUBLIC_DEPLOYMENT_ENV: process.env.NEXT_PUBLIC_DEPLOYMENT_ENV,
        MEMORY_LIMIT: process.env.MEMORY_LIMIT,
        NODE_OPTIONS: process.env.NODE_OPTIONS
      }
    });

    // 监听进程退出事件
    this.setupExitHandlers();
    
    this.initialized = true;
  }

  private setupExitHandlers(): void {
    // 正常退出
    process.on('exit', (code) => {
      this.log('PROCESS_EXIT', {
        code,
        reason: code === 0 ? 'Normal exit' : 'Exit with error code',
        timestamp: new Date().toISOString(),
        uptime: process.uptime(),
        memoryUsage: process.memoryUsage()
      });
    });

    // 未捕获的异常
    process.on('uncaughtException', (error, origin) => {
      this.log('UNCAUGHT_EXCEPTION', {
        error: {
          name: error.name,
          message: error.message,
          stack: error.stack,
          code: (error as any).code
        },
        origin,
        timestamp: new Date().toISOString(),
        uptime: process.uptime(),
        memoryUsage: process.memoryUsage()
      });
      
      console.error('Uncaught Exception:', error);
      
      // 延迟退出，确保日志写入
      setTimeout(() => {
        process.exit(1);
      }, 1000);
    });

    // 未处理的 Promise 拒绝
    process.on('unhandledRejection', (reason, promise) => {
      this.log('UNHANDLED_REJECTION', {
        reason: reason instanceof Error ? {
          name: reason.name,
          message: reason.message,
          stack: reason.stack
        } : reason,
        promise: promise.toString(),
        timestamp: new Date().toISOString(),
        uptime: process.uptime(),
        memoryUsage: process.memoryUsage()
      });
      
      console.error('Unhandled Rejection at:', promise, 'reason:', reason);
    });

    // 系统信号
    const signals = ['SIGTERM', 'SIGINT', 'SIGHUP', 'SIGUSR1', 'SIGUSR2'];
    signals.forEach(signal => {
      process.on(signal, () => {
        this.log('SIGNAL_RECEIVED', {
          signal,
          timestamp: new Date().toISOString(),
          uptime: process.uptime(),
          memoryUsage: process.memoryUsage()
        });
      });
    });
  }

  private log(eventType: string, data: any): void {
    try {
      // Skip excessive memory logging in production
      if (process.env.NODE_ENV === 'production') {
        if (eventType === 'MEMORY_CHECK') {
          // Only log memory checks every 20th time in production
          this.logEntryCount++;
          if (this.logEntryCount % 20 !== 0) {
            return;
          }
        }
        
        // Reduce log frequency for non-critical events in production
        if (['SIGNAL_RECEIVED', 'PROCESS_EXIT'].includes(eventType)) {
          // Only log these every 5th time
          this.logEntryCount++;
          if (this.logEntryCount % 5 !== 0) {
            return;
          }
        }
      }
      
      const logEntry = {
        eventType,
        timestamp: new Date().toISOString(),
        data
      };
      
      const logLine = JSON.stringify(logEntry) + '\n';
      
      // Check if we need to rotate log file
      if (this.logEntryCount >= MAX_LOG_ENTRIES) {
        this.rotateLogFile();
      }
      
      // 写入文件
      appendFileSync(this.currentLogFile, logLine);
      
      // 同时输出到控制台 - only for critical events in production
      if (process.env.NODE_ENV !== 'production' || 
          ['UNCAUGHT_EXCEPTION', 'PROCESS_EXIT', 'SIGNAL_RECEIVED'].includes(eventType)) {
        console.log(`[CRASH_LOGGER] ${eventType}:`, JSON.stringify(data, null, 2));
      }
      
      this.logEntryCount++;
    } catch (error) {
      console.error('Failed to write crash log:', error);
    }
  }
  
  private rotateLogFile(): void {
    try {
      // Create new log file
      this.currentLogFile = join(CRASH_LOG_DIR, `crash-${Date.now()}.log`);
      this.logEntryCount = 0;
      
      // Clean up old log files (keep only last 3)
      const files = require('fs').readdirSync(CRASH_LOG_DIR)
        .filter((f: string) => f.startsWith('crash-') && f.endsWith('.log'))
        .map((f: string) => join(CRASH_LOG_DIR, f))
        .sort();
      
      while (files.length > 3) {
        const oldestFile = files.shift();
        if (oldestFile && oldestFile !== this.currentLogFile) {
          require('fs').unlinkSync(oldestFile);
        }
      }
    } catch (error) {
      console.error('Failed to rotate crash log:', error);
    }
  }

  logMemoryPressure(level: string, usage: any): void {
    this.log('MEMORY_PRESSURE', {
      level,
      usage,
      timestamp: new Date().toISOString()
    });
  }

  logCustomEvent(eventType: string, data: any): void {
    this.log(eventType, data);
  }
}

// 导出单例
export const crashLogger = CrashLogger.getInstance();