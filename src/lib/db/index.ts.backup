import { PrismaClient } from '../types/prisma-types'
import { setupGlobalErrorHandlers } from '@/lib/utils/unified-error-handling'
import { validateCriticalEnvironmentVariables, logValidationResult } from '@/lib/startup/env-validation'
import { crashLogger } from '@/lib/crash-logger'
import { memoryMonitor } from '@/lib/enhanced-memory-monitor'

const globalForPrisma = globalThis as any & {
  prisma: PrismaClient | undefined
}

// Initialize crash logger immediately
crashLogger.initialize();

// Validate environment before initializing database
const validation = validateCriticalEnvironmentVariables();
logValidationResult(validation);

// Initialize Prisma client
let prisma: PrismaClient;

if (!validation.valid) {
  console.error('🚨 Cannot initialize database due to configuration errors');
  // Use a minimal client that will fail gracefully
  prisma = new PrismaClient({
    log: ['error'],
  });
} else {
  prisma = globalForPrisma.prisma ?? new PrismaClient({
    log: process.env.NODE_ENV === 'development' ? ['query', 'error', 'warn'] : ['error'],
  });
}

// Call global error handler setup
setupGlobalErrorHandlers();

// Start memory monitoring - use longer interval in production to reduce overhead
const monitorInterval = process.env.NODE_ENV === 'production' ? 300000 : 30000;
memoryMonitor.start(monitorInterval);

// Graceful shutdown
process.on('beforeExit', async () => {
  console.log('Shutting down gracefully...');
  memoryMonitor.stop();
  await prisma.$disconnect()
})

if (process.env.NODE_ENV !== 'production') globalForPrisma.prisma = prisma

export { prisma }